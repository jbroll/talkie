# sherpa.test - tcltest suite for the sherpa-onnx critcl binding.
# Run: LD_LIBRARY_PATH=$HOME/.local/lib tclsh sherpa.test
# Requires the built package (make all) and the staged streaming Zipformer model.

package require tcltest
namespace import ::tcltest::*

set here [file dirname [file normalize [info script]]]
lappend auto_path [file join $here .. lib]

set model_dir [file normalize [file join $here ../../../models/sherpa-onnx/sherpa-onnx-streaming-zipformer-en-2023-06-26]]

# Constraint: only run if the package loads and the model is present.
testConstraint sherpaReady [expr {![catch {package require sherpa}] && [file isdirectory $model_dir]}]

# Read 16kHz mono 16-bit PCM from a WAV, skipping the 44-byte header.
proc read_pcm {path} {
    set f [open $path rb]; set d [read $f]; close $f
    return [string range $d 44 end]
}

test version {reports the sherpa-onnx version string} -constraints sherpaReady -body {
    expr {[string length [sherpa::version]] > 0}
} -result 1

test load_model-globs-files {load_model resolves encoder/decoder/joiner/tokens from a dir} -constraints sherpaReady -body {
    set rec [sherpa::load_model -path $model_dir -rate 16000]
    set ok [string match "sherpa_recognizer*" $rec]
    $rec close
    set ok
} -result 1

test recognize-transcript {produces a plausible transcript for a known clip} -constraints sherpaReady -body {
    set rec [sherpa::load_model -path $model_dir -rate 16000]
    set pcm [read_pcm [file join $model_dir test_wavs 0.wav]]
    set text ""
    for {set i 0} {$i < [string length $pcm]} {incr i 3200} {
        $rec process [string range $pcm $i [expr {$i+3199}]]
    }
    set text [string trim [dict get [$rec final-result] text]]
    $rec close
    # Known transcript begins with these words.
    string match "AFTER EARLY NIGHTFALL*" $text
} -result 1

test recognize-endpoint {endpoint fires after trailing silence} -constraints sherpaReady -body {
    set rec [sherpa::load_model -path $model_dir -rate 16000]
    set pcm [read_pcm [file join $model_dir test_wavs 0.wav]]
    append pcm [binary format c* [lrepeat [expr {16000 * 3 * 2}] 0]]
    set saw_endpoint 0
    for {set i 0} {$i < [string length $pcm]} {incr i 3200} {
        set r [$rec process [string range $pcm $i [expr {$i+3199}]]]
        if {[dict get $r endpoint]} { set saw_endpoint 1 }
    }
    $rec close
    set saw_endpoint
} -result 1

test create-float-rate {a float device rate like 44100.0 must not crash (parsed as int)} -constraints sherpaReady -body {
    # Regression: -rate parsed with Tcl_GetSizeIntFromObj crashed on "44100.0".
    set rec [sherpa::load_model -path $model_dir -rate 44100.0]
    set ok [string match "sherpa_recognizer*" $rec]
    # 44.1kHz input must still resample and decode 16kHz test audio sensibly:
    # feeding the 16kHz wav while claiming 44100 is wrong, so just assert no crash + a dict.
    set r [$rec process [binary format c* [lrepeat 4410 0]]]
    $rec close
    list $ok [dict exists $r partial] [dict exists $r endpoint]
} -result {1 1 1}

test process-shape {process returns a dict with partial and endpoint keys} -constraints sherpaReady -body {
    set rec [sherpa::load_model -path $model_dir -rate 16000]
    set r [$rec process [binary format c* [lrepeat 3200 0]]]
    $rec close
    list [dict exists $r partial] [dict exists $r endpoint]
} -result {1 1}

set models_root [file normalize [file join $here ../../../models/sherpa-onnx]]
set parakeet_dir [file join $models_root sherpa-onnx-nemo-parakeet-tdt-0.6b-v2-int8]
set ctc_dir      [file join $models_root sherpa-onnx-nemo-parakeet_tdt_ctc_110m-en-36000-int8]
testConstraint parakeetReady [expr {[testConstraint sherpaReady] && [file isdirectory $parakeet_dir]}]
testConstraint ctcReady      [expr {[testConstraint sherpaReady] && [file isdirectory $ctc_dir]}]

test detect-kind {model kind is detected from the directory contents} -constraints sherpaReady -body {
    set r [list [sherpa::detect_kind $model_dir]]
    if {[file isdirectory $parakeet_dir]} { lappend r [sherpa::detect_kind $parakeet_dir] }
    if {[file isdirectory $ctc_dir]}      { lappend r [sherpa::detect_kind $ctc_dir] }
    set r
} -result {online-transducer offline-transducer offline-ctc}

test offline-parakeet-transcribe {offline transducer decodes a full utterance with punctuation/case} -constraints parakeetReady -body {
    set rec [sherpa::load_auto -path $parakeet_dir -rate 16000 -num-threads 4]
    set pcm [read_pcm [file join $parakeet_dir test_wavs 0.wav]]
    for {set i 0} {$i < [string length $pcm]} {incr i 6400} {
        set r [$rec process [string range $pcm $i [expr {$i+6399}]]]
        if {[dict get $r partial] ne "" || [dict get $r endpoint] != 0} { error "offline must not emit partial/endpoint" }
    }
    set text [dict get [$rec final-result] text]
    $rec close
    list [expr {[string length $text] > 20}] [expr {$text ne [string toupper $text]}]
} -result {1 1}

test offline-ctc-transcribe {CTC model decodes via load_auto} -constraints ctcReady -body {
    set rec [sherpa::load_auto -path $ctc_dir -rate 16000 -num-threads 4]
    set pcm [read_pcm [file join $ctc_dir test_wavs 0.wav]]
    for {set i 0} {$i < [string length $pcm]} {incr i 6400} {
        $rec process [string range $pcm $i [expr {$i+6399}]]
    }
    set text [string trim [dict get [$rec final-result] text]]
    $rec close
    expr {[string length $text] > 10}
} -result 1

set sv_dir [lindex [lsort [glob -nocomplain [file join $models_root sherpa-onnx-sense-voice*]]] end]
testConstraint svReady [expr {[testConstraint sherpaReady] && $sv_dir ne "" && [file isdirectory $sv_dir]}]

test detect-sensevoice {SenseVoice detected by dir name} -constraints svReady -body {
    sherpa::detect_kind $sv_dir
} -result sense-voice

test sensevoice-transcribe {SenseVoice decodes via load_auto} -constraints svReady -body {
    set rec [sherpa::load_auto -path $sv_dir -rate 16000 -num-threads 4]
    set wav [lindex [lsort [glob -nocomplain [file join $sv_dir test_wavs *.wav]]] 0]
    set pcm [read_pcm $wav]
    for {set i 0} {$i < [string length $pcm]} {incr i 6400} {
        $rec process [string range $pcm $i [expr {$i+6399}]]
    }
    set text [string trim [dict get [$rec final-result] text]]
    $rec close
    expr {[string length $text] > 5}
} -result 1

set ms_dir [lindex [lsort [glob -nocomplain [file join $models_root sherpa-onnx-moonshine*]]] end]
testConstraint msReady [expr {[testConstraint sherpaReady] && $ms_dir ne "" && [file isdirectory $ms_dir]}]

test detect-moonshine {Moonshine detected by dir name} -constraints msReady -body {
    sherpa::detect_kind $ms_dir
} -result moonshine

test moonshine-transcribe {Moonshine decodes with punctuation/case via load_auto} -constraints msReady -body {
    set rec [sherpa::load_auto -path $ms_dir -rate 16000 -num-threads 4]
    set pcm [read_pcm [lindex [lsort [glob [file join $ms_dir test_wavs *.wav]]] 0]]
    for {set i 0} {$i < [string length $pcm]} {incr i 6400} {
        $rec process [string range $pcm $i [expr {$i+6399}]]
    }
    set text [string trim [dict get [$rec final-result] text]]
    $rec close
    list [expr {[string length $text] > 20}] [expr {$text ne [string toupper $text]}]
} -result {1 1}

set wh_dir [lindex [lsort [glob -nocomplain [file join $models_root sherpa-onnx-whisper*]]] 0]
testConstraint whReady [expr {[testConstraint sherpaReady] && $wh_dir ne "" && [file isdirectory $wh_dir]}]

test detect-whisper {Whisper detected by dir name} -constraints whReady -body {
    sherpa::detect_kind $wh_dir
} -result whisper

test whisper-transcribe {Whisper decodes with punctuation/case via load_auto} -constraints whReady -body {
    set rec [sherpa::load_auto -path $wh_dir -rate 16000 -num-threads 4]
    set pcm [read_pcm [lindex [lsort [glob [file join $wh_dir test_wavs *.wav]]] 0]]
    for {set i 0} {$i < [string length $pcm]} {incr i 6400} {
        $rec process [string range $pcm $i [expr {$i+6399}]]
    }
    set text [string trim [dict get [$rec final-result] text]]
    $rec close
    list [expr {[string length $text] > 20}] [expr {$text ne [string toupper $text]}]
} -result {1 1}

cleanupTests
